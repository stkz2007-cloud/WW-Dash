<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Werewolf GM</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Kanit:wght@300;500&display=swap');
        * { box-sizing: border-box; }
        body { font-family: 'Kanit', sans-serif; background: #0f0f1a; color: #e0e0e0; padding: 10px; margin: 0; }
        .container { max-width: 100%; margin: auto; background: #161625; padding: 15px; border-radius: 15px; box-shadow: 0 10px 40px rgba(0,0,0,0.8); }
        h1 { text-align: center; color: #ff2e63; font-size: 1.5rem; margin-bottom: 15px; }
        
        .stats-bar { 
            display: grid; 
            grid-template-columns: 1fr 1fr; 
            gap: 10px; 
            margin-bottom: 20px; 
            background: #1a1a2e; 
            padding: 12px; 
            border-radius: 12px; 
            border: 1px solid #333; 
        }
        .stat-item { font-size: 0.85em; text-align: center; }
        .stat-cult { color: #b06ab3; font-weight: bold; }

        /* Event Display ปรับให้รองรับข้อความยาว */
        .event-control { background: #1a1a2e; padding: 15px; border-radius: 12px; margin-bottom: 20px; border: 1px dashed #444; text-align: center; }
        #eventDisplay { 
            margin-top: 15px; 
            padding: 15px; 
            background: #252535; 
            border-radius: 8px; 
            border-left: 5px solid #ff2e63;
            text-align: left;
            line-height: 1.5;
        }
        .dice-num { font-size: 2em; color: #ff2e63; font-weight: bold; display: block; text-align: center; margin-bottom: 5px; }

        .input-section { width: 100%; margin-bottom: 25px; }
        .input-row { display: flex; flex-direction: column; gap: 10px; margin-bottom: 10px; }
        .input-row input { width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #333; background: #2c2c2c; color: #fff; font-size: 1rem; }
        .add-btn { width: 100%; padding: 14px; background: #ff2e63; color: white; border: none; border-radius: 8px; cursor: pointer; font-weight: bold; font-size: 1rem; }
        
        .table-responsive { width: 100%; overflow-x: auto; -webkit-overflow-scrolling: touch; border-radius: 10px; border: 1px solid #252535; }
        table { width: 100%; min-width: 650px; border-collapse: collapse; }
        th { background: #1a1a2e; color: #ff2e63; padding: 10px; font-size: 0.75em; white-space: nowrap; }
        td { padding: 8px; text-align: center; background: #161625; border-bottom: 1px solid #252535; }
        
        .status-select { background: #0f3460; border: 1px solid #e94560; color: white; padding: 5px; border-radius: 5px; font-size: 0.85em; }
        .cupid-input { width: 60px; text-align: center; background: #2d1b24; color: #ff69b4; border: 1px solid #ff69b444; border-radius: 5px; font-size: 0.85em; }
        
        /* สไตล์ชื่อตามสถานะ */
        .name-tag { font-size: 0.9em; font-weight: bold; transition: 0.3s; }
        .status-dead-text { color: #8b0000 !important; text-decoration: line-through !important; }
        .row-dead-bg { background: #2a0000 !important; color: #666; }
        .status-muted { color: #f0a500 !important; }
        .status-exiled { color: #4b0082 !important; text-decoration: none !important; }

        .row-protected { border-left: 4px solid #00adff; background: rgba(0, 173, 255, 0.05) !important; }
        .row-cult { border-left: 4px solid #b06ab3; background: rgba(176, 106, 179, 0.05) !important; }
        .row-hooligan { border-left: 4px solid #d35400; }
        .row-lover { border-left: 4px solid #ff69b4; }

        @media (min-width: 600px) { 
            .input-row { flex-direction: row; } 
            .stats-bar { grid-template-columns: repeat(4, 1fr); } 
        }
    </style>
</head>
<body>

<div class="container">
    <h1>🐺 WEREWOLF GM</h1>
    
    <div class="stats-bar">
        <div class="stat-item">👥 ทั้งหมด: <span id="totalCount">0</span></div>
        <div class="stat-item" style="color:#4ecca3">🟢 มีชีวิต: <span id="aliveCount">0</span></div>
        <div class="stat-item" style="color:#ff4b2b">💀 ตายแล้ว: <span id="deadCount">0</span></div>
        <div class="stat-item stat-cult">👁️ ลัทธิ: <span id="cultCount">0</span></div>
    </div>

    <div class="event-control">
        <label style="cursor:pointer;"><input type="checkbox" id="useEvent" onchange="toggleEventPanel()"> ระบบเหตุการณ์ประจำวัน</label>
        <div id="eventPanel" style="display: none; margin-top: 15px;">
            <button class="add-btn" style="width: auto; padding: 8px 30px; margin-bottom: 10px;" id="rollBtn" onclick="rollEventWithAnim()">🎲 ทอยลูกเต๋า</button>
            <div id="eventDisplay" style="display:none;">
                <span class="dice-num" id="diceResult">?</span>
                <span id="eventDesc">รอกดปุ่มทอยลูกเต๋า...</span>
            </div>
        </div>
    </div>

    <div class="input-section">
        <div class="input-row">
            <input type="text" id="playerName" placeholder="ชื่อผู้เล่น">
            <input type="text" id="playerRole" placeholder="บทบาท">
        </div>
        <button class="add-btn" onclick="addPlayer()">➕ เพิ่มคนเล่นเข้ากระดาน</button>
    </div>

    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>ชื่อ</th>
                    <th>บทบาท</th>
                    <th>❤️ คู่</th>
                    <th>👊 อันธพาล</th>
                    <th>👁️ ลัทธิ</th>
                    <th>🛡️ กัน</th>
                    <th>⚙️ สถานะ</th>
                    <th>ลบ</th>
                </tr>
            </thead>
            <tbody id="playerList"></tbody>
        </table>
    </div>
</div>

<script>
    const events = { 
        2: "คืนถัดไป เป้าหมายของมนุษย์หมาป่า จะกลายเป็นมนุษย์หมาป่าตัวใหม่",
        3: "ผู้เล่นที่ถูกกล่าวหา 2 คน จะถูกกำจัดทันทีโดยไม่ต้องโหวต",
        4: "จะมีผู้เล่นถูกกำจัด 2 คนแทนที่จะเป็น 1 คนเหมือนปกติ",
        5: "บอกให้ผู้เล่นทุกคนรู้ว่าเทพพยากรณ์ถามบทบาทใครในคืนที่ผ่านมา",
        6: "ไม่มีเหตุการณ์ใดเกิดขึ้นในวันนี้", 
        7: "ไม่มีเหตุการณ์ใดเกิดขึ้นในวันนี้", 
        8: "ไม่มีเหตุการณ์ใดเกิดขึ้นในวันนี้",
        9: "เหตุการณ์ในวันนี้จะเหมือนกับเหตุการณ์เมื่อวานนี้",
        10: "ใช้การกำจัดผู้เล่นแบบตัดตัวเลือก (ทุกคนโหวตคนรอด คนรอดโหวตคนต่อไป คนสุดท้ายโดนประหาร),
        11: "ห้ามไม่ให้พูดคุยกันในวันนี้ นอกจากการทำการกล่าวหาเท่านั้น",
        12: "คืนถัดไป เป้าหมายของมนุษย์หมาป่า จะไม่ตายแต่จะต้องสูญเสียพลังพิเศษทั้งหมด"
    };

    function toggleEventPanel() { 
        document.getElementById('eventPanel').style.display = document.getElementById('useEvent').checked ? 'block' : 'none'; 
    }

    function rollEventWithAnim() {
        const btn = document.getElementById('rollBtn');
        const dNum = document.getElementById('diceResult');
        const dText = document.getElementById('eventDesc');
        const display = document.getElementById('eventDisplay');
        btn.disabled = true;
        display.style.display = 'block';
        
        let count = 0;
        const interval = setInterval(() => {
            dNum.innerText = Math.floor(Math.random() * 11) + 2;
            count += 100;
            if (count >= 1500) {
                clearInterval(interval);
                const res = (Math.floor(Math.random()*6)+1) + (Math.floor(Math.random()*6)+1);
                dNum.innerText = res;
                dText.innerText = events[res];
                btn.disabled = false;
            }
        }, 80);
    }

    function addPlayer() {
        const nInput = document.getElementById('playerName');
        const rInput = document.getElementById('playerRole');
        if (!nInput.value.trim()) return;
        const table = document.getElementById('playerList');
        const row = document.createElement('tr');
        row.setAttribute('data-name', nInput.value.trim());
        row.innerHTML = `
            <td><span class="name-tag">${nInput.value.trim()}</span></td>
            <td><input type="text" style="width:55px; background:none; border:1px solid #444; color:#4ecca3; text-align:center; font-size:0.8em;" value="${rInput.value.trim()}"></td>
            <td><input type="text" class="cupid-input" placeholder="..." oninput="this.parentElement.parentElement.classList.toggle('row-lover', this.value!=='')"></td>
            <td><input type="checkbox" onchange="this.parentElement.parentElement.classList.toggle('row-hooligan', this.checked)"></td>
            <td><input type="checkbox" class="cult-check" onchange="this.parentElement.parentElement.classList.toggle('row-cult', this.checked); updateStats();"></td>
            <td><input type="checkbox" class="protect-check" onchange="handleProtect(this)"></td>
            <td>
                <select class="status-select" onchange="handleStatus(this)">
                    <option value="normal">🟢 ปกติ</option>
                    <option value="dead">💀 ตาย</option>
                    <option value="muted">🤫 ใบ้</option>
                    <option value="exiled">⚖️ เนรเทศ</option>
                </select>
            </td>
            <td><button onclick="this.parentElement.parentElement.remove(); updateStats();" style="background:none; border:none; color:#555; cursor:pointer;">❌</button></td>
        `;
        table.appendChild(row);
        nInput.value = ""; rInput.value = "";
        updateStats();
    }

    function handleProtect(check) {
        const row = check.parentElement.parentElement;
        const loverName = row.querySelector('.cupid-input').value.trim();
        row.classList.toggle('row-protected', check.checked);
        if (check.checked) {
            const sel = row.querySelector('.status-select');
            if (sel.value === 'dead') { sel.value = 'normal'; handleStatus(sel); }
        }
        if (loverName) syncProtect(loverName, check.checked);
        updateStats();
    }

    function syncProtect(targetName, isProtected) {
        document.querySelectorAll('#playerList tr').forEach(row => {
            if (row.getAttribute('data-name') === targetName) {
                const check = row.querySelector('.protect-check');
                if (check.checked !== isProtected) {
                    check.checked = isProtected;
                    row.classList.toggle('row-protected', isProtected);
                    if (isProtected) {
                        const sel = row.querySelector('.status-select');
                        if (sel.value === 'dead') { sel.value = 'normal'; handleStatus(sel); }
                    }
                }
            }
        });
    }

    function handleStatus(select) {
        const row = select.parentElement.parentElement;
        const nameTag = row.querySelector('.name-tag');
        const name = row.getAttribute('data-name');
        const isProtected = row.querySelector('.protect-check').checked;
        const loverName = row.querySelector('.cupid-input').value.trim();

        row.classList.remove('row-dead-bg');
        nameTag.classList.remove('status-dead-text', 'status-muted', 'status-exiled');

        if (select.value === 'dead') {
            if (isProtected) { alert(`🛡️ ${name} ป้องกันอยู่!`); select.value = 'normal'; return; }
            row.classList.add('row-dead-bg');
            nameTag.classList.add('status-dead-text');
            if (loverName) syncDead(loverName);
        } else if (select.value === 'muted') {
            nameTag.classList.add('status-muted');
        } else if (select.value === 'exiled') {
            nameTag.classList.add('status-exiled');
        }
        updateStats();
    }

    function syncDead(targetName) {
        document.querySelectorAll('#playerList tr').forEach(row => {
            if (row.getAttribute('data-name') === targetName && !row.querySelector('.protect-check').checked) {
                const sel = row.querySelector('.status-select');
                if (sel.value !== 'dead') { sel.value = 'dead'; handleStatus(sel); }
            }
        });
    }

    function updateStats() {
        const rows = document.querySelectorAll('#playerList tr');
        let dead = 0, cultists = 0;
        rows.forEach(r => {
            const status = r.querySelector('.status-select').value;
            const isCultist = r.querySelector('.cult-check').checked;
            if (status === 'dead') dead++;
            else if (isCultist) cultists++;
        });
        document.getElementById('totalCount').innerText = rows.length;
        document.getElementById('aliveCount').innerText = rows.length - dead;
        document.getElementById('deadCount').innerText = dead;
        document.getElementById('cultCount').innerText = cultists;
    }
</script>
</body>
</html>
